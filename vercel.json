{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/web/osu-submit-modular-selector.php", "dest": "/api/osu-submit-modular-selector.py" },
    { "src": "/web/osu-osz2-getscores.php",          "dest": "/api/osu-osz2-getscores.py" },
    { "src": "/users",                                "dest": "/api/users.py" },
    { "src": "/login",                                "dest": "/api/auth.py" },
    { "src": "/logout",                               "dest": "/api/auth.py" },
    { "src": "/me",                                   "dest": "/api/auth.py" },
    { "src": "/me/(.*)",                              "dest": "/api/me.py" },
    { "src": "/admin(.*)",                            "dest": "/api/admin.py" },
    { "src": "/api/v1/(.*)",                          "dest": "/api/misc.py" },
    { "src": "/u/(.*)",                               "dest": "/api/misc.py" },
    { "src": "/avatar/(.*)",                          "dest": "/api/misc.py" },
    { "src": "/",                                     "dest": "/public/index.html" },
    { "src": "/(.*)",                                 "dest": "/api/misc.py" }
  ]
}
