# Scythe — Environment Variables
# Copy this to .env and fill in your values.
# Add ALL of these to Vercel AND Railway dashboards.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Settings → Database → Connection string (URI)
# Use the "Session mode" URI (port 5432)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=changeme123

# ── Server identity ───────────────────────────────────────────────────────────
SERVER_NAME=Scythe
SERVER_DOMAIN=scythe.gg

# ── Railway (Bancho only) ─────────────────────────────────────────────────────
# Railway sets PORT automatically — do not override it manually
