# Scythe — Environment Variables
# Copy this to .env and fill in your values.
# Add ALL of these to Vercel AND Railway dashboards.

# ── Supabase ──────────────────────────────────────────────────────────────────
# IMPORTANT: Railway is IPv4-only. Supabase's DIRECT connection (db.<ref>.supabase.co)
# is now IPv6-only on the free tier — using it from Railway WILL silently fail.
#
# Use the **Session pooler** URL instead (it's IPv4):
#   Supabase dashboard → Project Settings → Database → "Connection string"
#   → choose "Session pooler" (port 5432, host aws-0-<region>.pooler.supabase.com)
#
# Format:
#   postgresql://postgres.<project-ref>:<URL-ENCODED-PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# NOTE: any '$', '@', '#', etc. in your password MUST be URL-encoded.
#   $  → %24
#   @  → %40
#   #  → %23
#
# Example (your password "fragilevision93$GG" → "fragilevision93%24GG"):
SUPABASE_DB_URL=postgresql://postgres.pfxsxbaovgeimioqrswp:fragilevision93%24GG@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=fragilevision93$GG

# ── Server identity ───────────────────────────────────────────────────────────
SERVER_NAME=Scythe
SERVER_DOMAIN=0w0.fit

# ── Railway (Bancho only) ─────────────────────────────────────────────────────
# Railway sets PORT automatically — do not override it manually.
